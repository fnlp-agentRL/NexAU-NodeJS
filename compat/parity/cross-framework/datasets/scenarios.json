  "alias_toolcall": {
    "name": "alias_toolcall",
    "user_message": "请依次调用 Bash、Write、TodoWrite 三个工具，并在最后用一句话总结。",
    "responses": [
      {
        "content": "",
        "tool_calls": [
          {
            "id": "alias_call_1",
            "name": "Bash",
            "arguments": {
              "command": "echo alias-shell-ok"
            }
          }
        ]
      },
      {
        "content": "",
        "tool_calls": [
          {
            "id": "alias_call_2",
            "name": "Write",
            "arguments": {
              "file_path": "/tmp/nexau_alias_note.md",
              "content": "alias-write-ok"
            }
          }
        ]
      },
      {
        "content": "",
        "tool_calls": [
          {
            "id": "alias_call_3",
            "name": "TodoWrite",
            "arguments": {
              "todos": [
                {
                  "description": "alias parity item",
                  "status": "completed"
                }
              ]
            }
          }
        ]
      },
      {
        "content": "别名工具链执行完成。",
        "tool_calls": []
      }
    ]
  },
  "error_toolcall": {
    "name": "error_toolcall",
    "user_message": "请调用 read_file，但不要传入 file_path，用于测试工具参数校验错误路径。",
