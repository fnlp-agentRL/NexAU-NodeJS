      {
        "content": "",
        "tool_calls": [
          {
            "id": "err_call_1",
            "name": "read_file",
            "arguments": {}
          }
        ]
      },
      {
        "content": "错误路径测试结束。",
        "tool_calls": []
      }
    ]
  },
