{
  "prompt_toolcall": {
    "name": "prompt_toolcall",
    "user_message": "请先查看当前目录与项目笔记，再二次读取笔记片段，最后给出简要结论。",
    "responses": [
      {
        "content": "",
        "tool_calls": [
          {
            "id": "call_1",
            "name": "list_directory",
            "arguments": {
              "dir_path": "compat/parity/cross-framework/files"
            }
          },
          {
            "id": "call_2",
            "name": "read_file",
            "arguments": {
              "file_path": "compat/parity/cross-framework/files/project_notes.md",
              "offset": 0,
              "limit": 40
            }
          }
        ]
      },
      {
        "content": "",
        "tool_calls": [
          {
            "id": "call_3",
            "name": "read_file",
            "arguments": {
              "file_path": "compat/parity/cross-framework/files/project_notes.md",
              "offset": 2,
              "limit": 12
            }
          }
        ]
      },
      {
        "content": "目录浏览、笔记读取和记忆保存都已完成。",
        "tool_calls": []
      }
    ]
  },
  "prompt_toolcall_extended": {
    "name": "prompt_toolcall_extended",
    "user_message": "先查看目录和项目笔记，再执行两轮额外读取，最后输出一句话总结。",
    "responses": [
      {
        "content": "",
        "tool_calls": [
          {
            "id": "ext_call_1",
            "name": "list_directory",
            "arguments": {
              "dir_path": "compat/parity/cross-framework/files"
            }
          },
          {
            "id": "ext_call_2",
            "name": "read_file",
            "arguments": {
              "file_path": "compat/parity/cross-framework/files/project_notes.md",
              "offset": 1,
              "limit": 20
            }
          }
        ]
      },
      {
        "content": "",
        "tool_calls": [
          {
            "id": "ext_call_3",
            "name": "read_file",
            "arguments": {
              "file_path": "compat/parity/cross-framework/files/project_notes.md",
              "offset": 0,
              "limit": 8
            }
          }
        ]
      },
      {
        "content": "",
        "tool_calls": [
          {
            "id": "ext_call_4",
            "name": "list_directory",
            "arguments": {
              "dir_path": "compat/parity/cross-framework/files",
              "show_hidden": true
            }
          }
        ]
      },
      {
        "content": "扩展场景执行完成，文件读取与双记忆写入均成功。",
        "tool_calls": []
      }
    ]
  },
  "load_skill_toolcall": {
    "name": "load_skill_toolcall",
    "user_message": "先加载 save_memory 技能详情，再用一句话结束。",
    "responses": [
      {
        "content": "",
        "tool_calls": [
          {
            "id": "skill_call_1",
