{
  "name": "nexau-nodejs",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js/TypeScript compatibility rewrite for NexAU",
  "bin": {
    "nexau": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "parity:cross": "python3 compat/parity/cross-framework/run_compare.py",
    "parity:cross:check": "python3 compat/parity/cross-framework/run_compare.py --check --skip-if-baseline-missing",
    "parity:assets": "node compat/parity/cross-framework/compare_assets.mjs",
    "parity:assets:check": "node compat/parity/cross-framework/compare_assets.mjs --check --skip-if-baseline-missing",
    "parity:all": "node compat/parity/cross-framework/run_parity_suite.mjs",
    "parity:all:check": "node compat/parity/cross-framework/run_parity_suite.mjs --check --skip-if-baseline-missing",
    "parity:all:failures": "node compat/parity/cross-framework/run_parity_suite.mjs --failures-only --check --skip-if-baseline-missing",
    "parity:all:diagnose": "node compat/parity/cross-framework/diagnose_failures.mjs --skip-if-baseline-missing",
    "parity:all:triage": "node compat/parity/cross-framework/diagnose_failures.mjs --skip-if-baseline-missing --compact",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "commander": "^14.0.2",
    "minimatch": "^10.2.4",
    "yaml": "^2.8.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^4.0.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.23.0"
}
